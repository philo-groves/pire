{
	"name": "@philogroves/pimote",
	"version": "0.65.2",
	"description": "Remote access server for pire — view agent conversation, send messages, and get a shell from anywhere",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"pimote": "dist/main.js"
	},
	"scripts": {
		"build": "tsgo -p tsconfig.build.json",
		"dev": "tsgo -p tsconfig.build.json --watch",
		"clean": "shx rm -rf dist"
	},
	"dependencies": {
		"ws": "^8.18.0",
		"bcryptjs": "^2.4.3",
		"qrcode-terminal": "^0.12.0"
	},
	"peerDependencies": {
		"node-pty": ">=1.0.0"
	},
	"peerDependenciesMeta": {
		"node-pty": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/ws": "^8.5.14",
		"@types/bcryptjs": "^2.4.6",
		"@types/node": "^22.10.5"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
